# ==================================================
# My-co-Lab
# Git Ignore
# ==================================================

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*.pyo

# --------------------------------------------------
# Virtual Environments
# --------------------------------------------------
.venv/
venv/
env/

# --------------------------------------------------
# VS Code
# --------------------------------------------------
.vscode/

# --------------------------------------------------
# Operating System
# --------------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------------
# Logs
# --------------------------------------------------
*.log

# Keep documentation examples
!docs/**/*.log

# --------------------------------------------------
# Environment data
# --------------------------------------------------
data/environment/*.csv

# --------------------------------------------------
# Generated analysis
# --------------------------------------------------
analysis/reports/

# --------------------------------------------------
# Local backups
# --------------------------------------------------
backups/

# --------------------------------------------------
# Temporary files
# --------------------------------------------------
*.tmp
*.bak
*.swp

# --------------------------------------------------
# Camera output (daily folders)
# --------------------------------------------------
media/photos/20*/

# Keep setup documentation photos
!media/photos/setup/
!media/photos/setup/**

# --------------------------------------------------
# Videos
# --------------------------------------------------
media/videos/*.mp4

# --------------------------------------------------
# Timelapse
# --------------------------------------------------
media/timelapse/

# --------------------------------------------------
# Pico cache
# --------------------------------------------------
pico_backup/__pycache__/

